# CRM AI Hub - Environment Variables
# Copy this file to .env and fill in your values

# ==================== DATABASE ====================
DATABASE_URL="postgresql://user:password@localhost:5432/crm_ai_hub"

# ==================== AUTH ====================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Google OAuth (for login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==================== AI ====================
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ==================== AD PLATFORMS ====================

# Google Ads
GOOGLE_ADS_CLIENT_ID="your-google-ads-client-id"
GOOGLE_ADS_CLIENT_SECRET="your-google-ads-client-secret"
GOOGLE_ADS_DEVELOPER_TOKEN="your-developer-token"

# Meta (Facebook/Instagram)
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"

# TikTok
TIKTOK_APP_ID="your-tiktok-app-id"
TIKTOK_APP_SECRET="your-tiktok-app-secret"

# LinkedIn
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"

# X (Twitter)
X_API_KEY="your-x-api-key"
X_API_SECRET="your-x-api-secret"
X_ACCESS_TOKEN="your-x-access-token"
X_ACCESS_SECRET="your-x-access-secret"

# ==================== SOCIAL PUBLISHING ====================

# Instagram (uses Meta Graph API)
# Facebook (uses Meta Graph API)
# TikTok Content Posting API
# LinkedIn Marketing API
# YouTube Data API
YOUTUBE_API_KEY="your-youtube-api-key"

# ==================== LEAD GENERATION ====================

# Apollo.io
APOLLO_API_KEY="your-apollo-api-key"

# Hunter.io
HUNTER_API_KEY="your-hunter-api-key"

# BuiltWith
BUILTWITH_API_KEY="your-builtwith-api-key"

# Crunchbase
CRUNCHBASE_API_KEY="your-crunchbase-api-key"

# Email verification
NEVERBOUNCE_API_KEY="your-neverbounce-api-key"

# ==================== EMAIL SENDING ====================
RESEND_API_KEY="your-resend-api-key"
FROM_EMAIL="noreply@yourdomain.com"

# ==================== STORAGE ====================
# For storing social media creatives and uploads
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ==================== REDIS ====================
# For job queues and caching
REDIS_URL="redis://localhost:6379"
