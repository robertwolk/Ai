// CRM AI Hub - Prisma Schema
// Generated from crm-hub skill database-schema reference

generator client {
  provider = "prisma-client-js"
  }

  datasource db {
    provider = "postgresql"
      url      = env("DATABASE_URL")
      }

      // ==================== AUTH ====================

      model User {
        id            String    @id @default(cuid())
          name          String?
            email         String    @unique
              emailVerified DateTime?
                image         String?
                  role          UserRole  @default(MEMBER)
                    createdAt     DateTime  @default(now())
                      updatedAt     DateTime  @updatedAt

                        accounts      Account[]
                          sessions      Session[]
                            activities    Activity[]
                              tasksAssigned Activity[] @relation("AssignedTo")
                                socialPosts   SocialPost[]
                                  approvals     SocialPostApproval[]
                                  }

                                  enum UserRole {
                                    ADMIN
                                      MANAGER
                                        MEMBER
                                          VIEWER
                                          }

                                          model Account {
                                            id                String  @id @default(cuid())
                                              userId            String
                                                type              String
                                                  provider          String
                                                    providerAccountId String
                                                      refresh_token     String? @db.Text
                                                        access_token      String? @db.Text
                                                          expires_at        Int?
                                                            token_type        String?
                                                              scope             String?
                                                                id_token          String? @db.Text
                                                                  session_state     String?
                                                                    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
                                                                      @@unique([provider, providerAccountId])
                                                                      }

                                                                      model Session {
                                                                        id           String   @id @default(cuid())
                                                                          sessionToken String   @unique
                                                                            userId       String
                                                                              expires      DateTime
                                                                                user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
                                                                                }

                                                                                // ==================== CRM CORE ====================

                                                                                model Contact {
                                                                                  id              String          @id @default(cuid())
                                                                                    firstName       String
                                                                                      lastName        String
                                                                                        email           String          @unique
                                                                                          phone           String?
                                                                                            company         String?
                                                                                              jobTitle        String?
                                                                                                source          LeadSource      @default(MANUAL)
                                                                                                  sourceCampaign  String?
                                                                                                    sourceAd        String?
                                                                                                      sourceKeyword   String?
                                                                                                        utmSource       String?
                                                                                                          utmMedium       String?
                                                                                                            utmCampaign     String?
                                                                                                              utmContent      String?
                                                                                                                utmTerm         String?
                                                                                                                  gclid           String?
                                                                                                                    fbclid          String?
                                                                                                                      tags            String[]
                                                                                                                        customFields    Json?
                                                                                                                          lifecycleStage  LifecycleStage  @default(LEAD)
                                                                                                                            leadScore       Int             @default(0)
                                                                                                                              acquisitionCost Decimal?
                                                                                                                                createdAt       DateTime        @default(now())
                                                                                                                                  updatedAt       DateTime        @updatedAt
                                                                                                                                  
                                                                                                                                    deals           Deal[]
                                                                                                                                      activities      Activity[]
                                                                                                                                        attributionEvents AttributionEvent[]
                                                                                                                                          leadGenLead     LeadGenLead?
                                                                                                                                          }
                                                                                                                                          
                                                                                                                                          enum LeadSource {
                                                                                                                                            GOOGLE_ADS
                                                                                                                                              META_ADS
                                                                                                                                                X_ADS
                                                                                                                                                  TIKTOK_ADS
                                                                                                                                                    LINKEDIN_ADS
                                                                                                                                                      ORGANIC
                                                                                                                                                        REFERRAL
                                                                                                                                                          COLD_EMAIL
                                                                                                                                                            MANUAL
                                                                                                                                                              SCRAPED
                                                                                                                                                              }
                                                                                                                                                              
                                                                                                                                                              enum LifecycleStage {
                                                                                                                                                                SUBSCRIBER
                                                                                                                                                                  LEAD
                                                                                                                                                                    MQL
                                                                                                                                                                      SQL
                                                                                                                                                                        OPPORTUNITY
                                                                                                                                                                          CUSTOMER
                                                                                                                                                                            EVANGELIST
                                                                                                                                                                            }
                                                                                                                                                                            
                                                                                                                                                                            model Deal {
                                                                                                                                                                              id              String      @id @default(cuid())
                                                                                                                                                                                contactId       String
                                                                                                                                                                                  title           String
                                                                                                                                                                                    value           Decimal?
                                                                                                                                                                                      currency        String      @default("USD")
                                                                                                                                                                                        stage           DealStage   @default(LEAD)
                                                                                                                                                                                          pipelineId      String
                                                                                                                                                                                            probability     Int         @default(0)
                                                                                                                                                                                              expectedClose   DateTime?
                                                                                                                                                                                                actualClose     DateTime?
                                                                                                                                                                                                  lostReason      String?
                                                                                                                                                                                                    sourcePlatform  LeadSource?
                                                                                                                                                                                                      sourceCampaign  String?
                                                                                                                                                                                                        createdAt       DateTime    @default(now())
                                                                                                                                                                                                          updatedAt       DateTime    @updatedAt
                                                                                                                                                                                                          
                                                                                                                                                                                                            contact         Contact     @relation(fields: [contactId], references: [id])
                                                                                                                                                                                                              pipeline        Pipeline    @relation(fields: [pipelineId], references: [id])
                                                                                                                                                                                                                activities      Activity[]
                                                                                                                                                                                                                  conversionImports ConversionImport[]
                                                                                                                                                                                                                  }
                                                                                                                                                                                                                  
                                                                                                                                                                                                                  enum DealStage {
                                                                                                                                                                                                                    LEAD
                                                                                                                                                                                                                      QUALIFIED
                                                                                                                                                                                                                        MEETING_BOOKED
                                                                                                                                                                                                                          PROPOSAL_SENT
                                                                                                                                                                                                                            NEGOTIATION
                                                                                                                                                                                                                              WON
                                                                                                                                                                                                                                LOST
                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                
                                                                                                                                                                                                                                model Pipeline {
                                                                                                                                                                                                                                  id         String   @id @default(cuid())
                                                                                                                                                                                                                                    name       String
                                                                                                                                                                                                                                      stages     Json
                                                                                                                                                                                                                                        isDefault  Boolean  @default(false)
                                                                                                                                                                                                                                          createdAt  DateTime @default(now())
                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                            deals      Deal[]
                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                            model Activity {
                                                                                                                                                                                                                                              id          String       @id @default(cuid())
                                                                                                                                                                                                                                                contactId   String?
                                                                                                                                                                                                                                                  dealId      String?
                                                                                                                                                                                                                                                    createdBy   String?
                                                                                                                                                                                                                                                      assignedTo  String?
                                                                                                                                                                                                                                                        type        ActivityType
                                                                                                                                                                                                                                                          subject     String
                                                                                                                                                                                                                                                            body        String?
                                                                                                                                                                                                                                                              outcome     String?
                                                                                                                                                                                                                                                                dueDate     DateTime?
                                                                                                                                                                                                                                                                  completedAt DateTime?
                                                                                                                                                                                                                                                                    createdAt   DateTime     @default(now())
                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                      contact     Contact?     @relation(fields: [contactId], references: [id])
                                                                                                                                                                                                                                                                        deal        Deal?        @relation(fields: [dealId], references: [id])
                                                                                                                                                                                                                                                                          creator     User?        @relation(fields: [createdBy], references: [id])
                                                                                                                                                                                                                                                                            assignee    User?        @relation("AssignedTo", fields: [assignedTo], references: [id])
                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                            enum ActivityType {
                                                                                                                                                                                                                                                                              CALL
                                                                                                                                                                                                                                                                                EMAIL
                                                                                                                                                                                                                                                                                  MEETING
                                                                                                                                                                                                                                                                                    NOTE
                                                                                                                                                                                                                                                                                      TASK
                                                                                                                                                                                                                                                                                        AD_CLICK
                                                                                                                                                                                                                                                                                          PAGE_VIEW
                                                                                                                                                                                                                                                                                            FORM_SUBMIT
                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                            // ==================== AD PLATFORMS ====================
                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                            model AdAccount {
                                                                                                                                                                                                                                                                                              id             String       @id @default(cuid())
                                                                                                                                                                                                                                                                                                platform       AdPlatform
                                                                                                                                                                                                                                                                                                  accountId      String
                                                                                                                                                                                                                                                                                                    accountName    String
                                                                                                                                                                                                                                                                                                      accessToken    String       @db.Text
                                                                                                                                                                                                                                                                                                        refreshToken   String?      @db.Text
                                                                                                                                                                                                                                                                                                          tokenExpiresAt DateTime?
                                                                                                                                                                                                                                                                                                            currency       String       @default("USD")
                                                                                                                                                                                                                                                                                                              timezone       String       @default("UTC")
                                                                                                                                                                                                                                                                                                                isActive       Boolean      @default(true)
                                                                                                                                                                                                                                                                                                                  lastSyncedAt   DateTime?
                                                                                                                                                                                                                                                                                                                    createdAt      DateTime     @default(now())
                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                      campaigns      Campaign[]
                                                                                                                                                                                                                                                                                                                        audienceSyncs  AudienceSync[]
                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                        enum AdPlatform {
                                                                                                                                                                                                                                                                                                                          GOOGLE
                                                                                                                                                                                                                                                                                                                            META
                                                                                                                                                                                                                                                                                                                              X
                                                                                                                                                                                                                                                                                                                                TIKTOK
                                                                                                                                                                                                                                                                                                                                  LINKEDIN
                                                                                                                                                                                                                                                                                                                                    MICROSOFT
                                                                                                                                                                                                                                                                                                                                      APPLE
                                                                                                                                                                                                                                                                                                                                        YOUTUBE
                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                        model Campaign {
                                                                                                                                                                                                                                                                                                                                          id               String     @id @default(cuid())
                                                                                                                                                                                                                                                                                                                                            adAccountId      String
                                                                                                                                                                                                                                                                                                                                              platform         AdPlatform
                                                                                                                                                                                                                                                                                                                                                platformId       String
                                                                                                                                                                                                                                                                                                                                                  name             String
                                                                                                                                                                                                                                                                                                                                                    objective        String?
                                                                                                                                                                                                                                                                                                                                                      status           AdStatus   @default(ACTIVE)
                                                                                                                                                                                                                                                                                                                                                        dailyBudget      Decimal?
                                                                                                                                                                                                                                                                                                                                                          lifetimeBudget   Decimal?
                                                                                                                                                                                                                                                                                                                                                            startDate        DateTime?
                                                                                                                                                                                                                                                                                                                                                              endDate          DateTime?
                                                                                                                                                                                                                                                                                                                                                                createdAt        DateTime   @default(now())
                                                                                                                                                                                                                                                                                                                                                                  updatedAt        DateTime   @updatedAt
                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                    adAccount        AdAccount  @relation(fields: [adAccountId], references: [id])
                                                                                                                                                                                                                                                                                                                                                                      adSets           AdSet[]
                                                                                                                                                                                                                                                                                                                                                                        adMetrics        AdMetric[]
                                                                                                                                                                                                                                                                                                                                                                          attributionEvents AttributionEvent[]
                                                                                                                                                                                                                                                                                                                                                                            conversionImports ConversionImport[]
                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                            enum AdStatus {
                                                                                                                                                                                                                                                                                                                                                                              ACTIVE
                                                                                                                                                                                                                                                                                                                                                                                PAUSED
                                                                                                                                                                                                                                                                                                                                                                                  DELETED
                                                                                                                                                                                                                                                                                                                                                                                    COMPLETED
                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                    model AdSet {
                                                                                                                                                                                                                                                                                                                                                                                      id             String     @id @default(cuid())
                                                                                                                                                                                                                                                                                                                                                                                        campaignId     String
                                                                                                                                                                                                                                                                                                                                                                                          platformId     String
                                                                                                                                                                                                                                                                                                                                                                                            name           String
                                                                                                                                                                                                                                                                                                                                                                                              status         AdStatus   @default(ACTIVE)
                                                                                                                                                                                                                                                                                                                                                                                                targeting      Json?
                                                                                                                                                                                                                                                                                                                                                                                                  dailyBudget    Decimal?
                                                                                                                                                                                                                                                                                                                                                                                                    bidStrategy    String?
                                                                                                                                                                                                                                                                                                                                                                                                      bidAmount      Decimal?
                                                                                                                                                                                                                                                                                                                                                                                                        createdAt      DateTime   @default(now())
                                                                                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                                                                                          campaign       Campaign   @relation(fields: [campaignId], references: [id])
                                                                                                                                                                                                                                                                                                                                                                                                            ads            Ad[]
                                                                                                                                                                                                                                                                                                                                                                                                              adMetrics      AdMetric[]
                                                                                                                                                                                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                                                                                                                                                                              model Ad {
                                                                                                                                                                                                                                                                                                                                                                                                                id          String   @id @default(cuid())
                                                                                                                                                                                                                                                                                                                                                                                                                  adSetId     String
                                                                                                                                                                                                                                                                                                                                                                                                                    platformId  String
                                                                                                                                                                                                                                                                                                                                                                                                                      name        String
                                                                                                                                                                                                                                                                                                                                                                                                                        status      AdStatus @default(ACTIVE)
                                                                                                                                                                                                                                                                                                                                                                                                                          format      AdFormat
                                                                                                                                                                                                                                                                                                                                                                                                                            headline    String?
                                                                                                                                                                                                                                                                                                                                                                                                                              body        String?  @db.Text
                                                                                                                                                                                                                                                                                                                                                                                                                                cta         String?
                                                                                                                                                                                                                                                                                                                                                                                                                                  landingUrl  String?
                                                                                                                                                                                                                                                                                                                                                                                                                                    creativeUrl String?
                                                                                                                                                                                                                                                                                                                                                                                                                                      createdAt   DateTime @default(now())
                                                                                                                                                                                                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                                                                                                                                                                                        adSet       AdSet    @relation(fields: [adSetId], references: [id])
                                                                                                                                                                                                                                                                                                                                                                                                                                          adMetrics   AdMetric[]
                                                                                                                                                                                                                                                                                                                                                                                                                                            attributionEvents AttributionEvent[]
                                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                                                                            enum AdFormat {
                                                                                                                                                                                                                                                                                                                                                                                                                                              IMAGE
                                                                                                                                                                                                                                                                                                                                                                                                                                                VIDEO
                                                                                                                                                                                                                                                                                                                                                                                                                                                  CAROUSEL
                                                                                                                                                                                                                                                                                                                                                                                                                                                    TEXT
                                                                                                                                                                                                                                                                                                                                                                                                                                                      SPARK_AD
                                                                                                                                                                                                                                                                                                                                                                                                                                                        RESPONSIVE_SEARCH
                                                                                                                                                                                                                                                                                                                                                                                                                                                          PERFORMANCE_MAX
                                                                                                                                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                                                                                                                                                                                                                          model AdMetric {
                                                                                                                                                                                                                                                                                                                                                                                                                                                            id              String     @id @default(cuid())
                                                                                                                                                                                                                                                                                                                                                                                                                                                              adId            String?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                adSetId         String?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                  campaignId      String
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    platform        AdPlatform
                                                                                                                                                                                                                                                                                                                                                                                                                                                                      date            DateTime
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        hour            Int?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                          impressions     Int        @default(0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                            reach           Int        @default(0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                              clicks          Int        @default(0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                linkClicks      Int        @default(0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  ctr             Decimal?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    cpc             Decimal?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      cpm             Decimal?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        spend           Decimal    @default(0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          conversions     Int        @default(0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            conversionValue Decimal    @default(0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              cpa             Decimal?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                roas            Decimal?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  videoViews      Int        @default(0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    frequency       Decimal?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      createdAt       DateTime   @default(now())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        ad              Ad?        @relation(fields: [adId], references: [id])
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          adSet           AdSet?     @relation(fields: [adSetId], references: [id])
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            campaign        Campaign   @relation(fields: [campaignId], references: [id])
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            // ==================== OPTIMIZATION ====================
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            model OptimizationLog {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              id           String        @id @default(cuid())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                platform     AdPlatform?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  objectType   OptObjectType
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    objectId     String
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      objectName   String
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        action       OptAction
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          beforeValue  String?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            afterValue   String?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              reason       String        @db.Text
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                metricsSnapshot Json?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  isUndone     Boolean       @default(false)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    undoneAt     DateTime?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      createdAt    DateTime      @default(now())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      enum OptObjectType {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        CAMPAIGN
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          AD_SET
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            AD
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              AUDIENCE
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                BUDGET
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                enum OptAction {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  BUDGET_INCREASE
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    BUDGET_DECREASE
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      PAUSE
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        ENABLE
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          BID_CHANGE
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            AUDIENCE_EXCLUDE
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              CREATIVE_PAUSE
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                LOOKALIKE_REFRESH
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                model AudienceSync {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  id            String          @id @default(cuid())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    name          String
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      crmSegment    Json
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        platforms     String[]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          syncType      AudienceSyncType
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            adAccountId   String?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              contactCount  Int             @default(0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                lastSyncedAt  DateTime?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  syncFrequency SyncFrequency   @default(DAILY)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    createdAt     DateTime        @default(now())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      adAccount     AdAccount?      @relation(fields: [adAccountId], references: [id])
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      enum AudienceSyncType {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        TARGETING
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          EXCLUSION
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            LOOKALIKE_SOURCE
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            enum SyncFrequency {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              DAILY
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                WEEKLY
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  MANUAL
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  // ==================== ATTRIBUTION ====================
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  model AttributionEvent {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    id         String    @id @default(cuid())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      contactId  String?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        eventType  EventType
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          platform   AdPlatform?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            campaignId String?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              adId       String?
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                url        String?
