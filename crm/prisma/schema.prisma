generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================
// ENUMS (SQLite doesn't support enums natively,
// so we use String fields with comments)
// ============================================

// ============================================
// AUTH & USERS
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  role          String    @default("MEMBER") // ADMIN, MANAGER, MEMBER, VIEWER
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  activities    Activity[]
  assignedDeals Deal[]    @relation("AssignedDeals")
  postApprovals PostApproval[]
  targetProfiles TargetProfile[]

  @@map("users")
}

// ============================================
// CRM CORE
// ============================================

model Contact {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  phone           String?
  company         String?
  jobTitle        String?
  source          String   @default("MANUAL") // GOOGLE_ADS, META_ADS, X_ADS, TIKTOK_ADS, ORGANIC, REFERRAL, COLD_EMAIL, MANUAL
  sourceCampaign  String?
  sourceAd        String?
  sourceKeyword   String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  gclid           String?
  fbclid          String?
  tags            String   @default("[]") // JSON array of tags
  customFields    String   @default("{}") // JSON object
  lifecycleStage  String   @default("LEAD") // SUBSCRIBER, LEAD, MQL, SQL, OPPORTUNITY, CUSTOMER, EVANGELIST
  leadScore       Int      @default(0)
  acquisitionCost Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deals           Deal[]
  activities      Activity[]
  leadScores      LeadScore[]
  scrapedLeads    ScrapedLead[]
  emailEnrollments EmailSequenceEnrollment[]

  @@map("contacts")
}

model Deal {
  id                String    @id @default(cuid())
  contactId         String
  contact           Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title             String
  value             Float
  currency          String    @default("USD")
  stage             String    @default("LEAD") // LEAD, QUALIFIED, MEETING_BOOKED, PROPOSAL_SENT, NEGOTIATION, WON, LOST
  pipelineId        String
  pipeline          Pipeline  @relation(fields: [pipelineId], references: [id])
  probability       Int       @default(0)
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  lostReason        String?
  sourcePlatform    String?   // GOOGLE, META, X, TIKTOK
  sourceCampaign    String?
  assignedToId      String?
  assignedTo        User?     @relation("AssignedDeals", fields: [assignedToId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  activities        Activity[]

  @@map("deals")
}

model Pipeline {
  id        String  @id @default(cuid())
  name      String
  stages    String  @default("[]") // JSON array of {name, probability}
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals     Deal[]

  @@map("pipelines")
}

model Activity {
  id          String    @id @default(cuid())
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId      String?
  deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  type        String    // CALL, EMAIL, MEETING, NOTE, TASK, AD_CLICK, PAGE_VIEW, FORM_SUBMIT
  subject     String
  body        String?
  outcome     String?
  dueDate     DateTime?
  completedAt DateTime?
  assignedToId String?
  assignedTo  User?     @relation(fields: [assignedToId], references: [id])
  createdAt   DateTime  @default(now())

  @@map("activities")
}

// ============================================
// AD PLATFORM
// ============================================

model AdAccount {
  id           String   @id @default(cuid())
  platform     String   // GOOGLE, META, X, TIKTOK
  accountId    String
  accountName  String
  accessToken  String?
  refreshToken String?
  tokenExpiresAt DateTime?
  currency     String   @default("USD")
  timezone     String   @default("America/New_York")
  isActive     Boolean  @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns    Campaign[]

  @@map("ad_accounts")
}

model Campaign {
  id            String    @id @default(cuid())
  adAccountId   String
  adAccount     AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  platform      String    // GOOGLE, META, X, TIKTOK
  externalId    String?
  name          String
  status        String    @default("DRAFT") // ACTIVE, PAUSED, COMPLETED, DRAFT, ARCHIVED
  objective     String?
  budgetDaily   Float?
  budgetTotal   Float?
  startDate     DateTime?
  endDate       DateTime?
  targeting     String    @default("{}") // JSON
  metrics       String    @default("{}") // JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  adSets        AdSet[]
  campaignMetrics CampaignMetric[]
  optimizationLogs OptimizationLog[]

  @@map("campaigns")
}

model AdSet {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  status      String   @default("ACTIVE")
  targeting   String   @default("{}") // JSON
  budgetDaily Float?
  bidAmount   Float?
  bidStrategy String?
  metrics     String   @default("{}") // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ads         Ad[]

  @@map("ad_sets")
}

model Ad {
  id        String   @id @default(cuid())
  adSetId   String
  adSet     AdSet    @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  name      String
  status    String   @default("ACTIVE")
  creative  String   @default("{}") // JSON: headline, description, image_url, video_url, cta
  metrics   String   @default("{}") // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ads")
}

// ============================================
// AD MONITORING & OPTIMIZATION
// ============================================

model CampaignMetric {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date            DateTime
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  ctr             Float    @default(0)
  cpc             Float    @default(0)
  cpm             Float    @default(0)
  spend           Float    @default(0)
  conversions     Int      @default(0)
  conversionValue Float    @default(0)
  roas            Float    @default(0)
  cpa             Float    @default(0)
  createdAt       DateTime @default(now())

  @@unique([campaignId, date])
  @@map("campaign_metrics")
}

model OptimizationLog {
  id          String   @id @default(cuid())
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  ruleName    String
  actionType  String   // BUDGET_CHANGE, PAUSE, ENABLE, BID_CHANGE, AUDIENCE_CHANGE, CREATIVE_CHANGE
  description String
  oldValue    String?
  newValue    String?
  impact      String?  // JSON: metrics before and after
  canUndo     Boolean  @default(true)
  undone      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("optimization_logs")
}

model OptimizationRule {
  id           String   @id @default(cuid())
  name         String
  type         String   // BUDGET, CREATIVE, AUDIENCE, BID
  conditions   String   @default("[]") // JSON array of conditions
  actions      String   @default("[]") // JSON array of actions
  isEnabled    Boolean  @default(true)
  lastTriggered DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("optimization_rules")
}

// ============================================
// SOCIAL MEDIA
// ============================================

model SocialAccount {
  id             String   @id @default(cuid())
  platform       String   // INSTAGRAM, FACEBOOK, X, TIKTOK, LINKEDIN, YOUTUBE
  accountId      String
  accountName    String
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  followerCount  Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  posts          SocialPost[]

  @@map("social_accounts")
}

model SocialPost {
  id              String    @id @default(cuid())
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  content         String
  platform        String    // INSTAGRAM, FACEBOOK, X, TIKTOK, LINKEDIN, YOUTUBE
  status          String    @default("DRAFT") // DRAFT, REVIEW, APPROVED, SCHEDULED, PUBLISHED, FAILED
  scheduledAt     DateTime?
  publishedAt     DateTime?
  mediaUrls       String    @default("[]") // JSON array
  hashtags        String    @default("[]") // JSON array
  metrics         String    @default("{}") // JSON: likes, comments, shares, reach, impressions
  contentThemeId  String?
  contentTheme    ContentTheme? @relation(fields: [contentThemeId], references: [id])
  contentSeriesId String?
  contentSeries   ContentSeries? @relation(fields: [contentSeriesId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  approvals       PostApproval[]

  @@map("social_posts")
}

model ContentTheme {
  id           String   @id @default(cuid())
  name         String
  description  String?
  color        String   @default("#3B82F6")
  contentRatio Float    @default(0.25) // What % of content should be this theme
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts        SocialPost[]
  series       ContentSeries[]

  @@map("content_themes")
}

model ContentSeries {
  id          String   @id @default(cuid())
  name        String
  themeId     String
  theme       ContentTheme @relation(fields: [themeId], references: [id])
  frequency   String   @default("WEEKLY") // DAILY, WEEKLY, BIWEEKLY, MONTHLY
  dayOfWeek   Int?     // 0=Sun, 6=Sat
  timeOfDay   String?  // "10:00"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       SocialPost[]

  @@map("content_series")
}

model PostApproval {
  id           String     @id @default(cuid())
  socialPostId String
  socialPost   SocialPost @relation(fields: [socialPostId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  status       String     @default("PENDING") // PENDING, APPROVED, REJECTED, CHANGES_REQUESTED
  comment      String?
  createdAt    DateTime   @default(now())

  @@map("post_approvals")
}

// ============================================
// LEAD GENERATION
// ============================================

model LeadGenCampaign {
  id               String   @id @default(cuid())
  name             String
  status           String   @default("DRAFT") // DRAFT, ACTIVE, PAUSED, COMPLETED
  targetProfile    String   @default("{}") // JSON
  scrapingStrategy String   @default("{}") // JSON
  resultsSummary   String   @default("{}") // JSON
  targetLeadCount  Int      @default(500)
  budget           Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  scrapedLeads     ScrapedLead[]

  @@map("lead_gen_campaigns")
}

model ScrapedLead {
  id                String   @id @default(cuid())
  leadGenCampaignId String
  leadGenCampaign   LeadGenCampaign @relation(fields: [leadGenCampaignId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact? @relation(fields: [contactId], references: [id])
  rawData           String   @default("{}") // JSON
  enrichmentData    String   @default("{}") // JSON
  fitScore          Int      @default(0)
  intentScore       Int      @default(0)
  engagementScore   Int      @default(0)
  totalScore        Int      @default(0)
  grade             String   @default("D") // A, B, C, D
  status            String   @default("NEW") // NEW, ENRICHED, SCORED, CONTACTED, QUALIFIED, CONVERTED, REJECTED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("scraped_leads")
}

model ScrapingSource {
  id             String @id @default(cuid())
  name           String
  type           String // API, WEB_SCRAPING, MANUAL
  apiKey         String?
  costPerLookup  Float  @default(0)
  totalLookups   Int    @default(0)
  successRate    Float  @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("scraping_sources")
}

model TargetProfile {
  id          String   @id @default(cuid())
  name        String
  criteria    String   @default("{}") // JSON
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("target_profiles")
}

model LeadScore {
  id              String   @id @default(cuid())
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  fitScore        Int      @default(0)
  intentScore     Int      @default(0)
  engagementScore Int      @default(0)
  totalScore      Int      @default(0)
  grade           String   @default("D") // A, B, C, D
  scoringDetails  String   @default("{}") // JSON
  createdAt       DateTime @default(now())

  @@map("lead_scores")
}

model EmailSequence {
  id        String   @id @default(cuid())
  name      String
  type      String   // COLD, WARM, NURTURE, ONBOARDING
  steps     String   @default("[]") // JSON array of {delay, subject, body, type}
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments EmailSequenceEnrollment[]

  @@map("email_sequences")
}

model EmailSequenceEnrollment {
  id            String    @id @default(cuid())
  sequenceId    String
  sequence      EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStep   Int       @default(0)
  status        String    @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, BOUNCED, UNSUBSCRIBED
  enrolledAt    DateTime  @default(now())
  completedAt   DateTime?

  @@map("email_sequence_enrollments")
}
